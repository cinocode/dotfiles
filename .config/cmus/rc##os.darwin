unbind common +
bind common + vol +5%
unbind common -
bind common - vol -5%
bind common ; shell ~/.bin/cmus_update
set aaa_mode=artist
set follow=true
set repeat=true
set continue=true
set show_remaining_time=true
set shuffle=false
set pl_env_vars=MUSIC_DIR
set status_display_program=cmusfm
set dsp.coreaudio.sync_sample_rate=true
set softvol=true
set output_plugin=ao
