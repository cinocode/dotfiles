Xft.dpi: 96
Xft.antialias: true
Xft.hinting: true
Xft.rgba: rgb
Xft.autohint: false
Xft.hintstyle: hintslight
Xft.lcdfilter: lcddefault

*foreground: #a9b1d6
*background: #1a1b26
*cursorColor: #a9b1d6
*highlightColor:#3A3F4B
*color0: #1a1b26
*color8: #4e5173
*color1: #F7768E
*color9: #F7768E
*color2: #9ECE6A
*color10: #9ECE6A
*color3: #E0AF68
*color11: #E0AF68
*color4: #7AA2F7
*color12: #7AA2F7
*color5: #9a7ecc
*color13: #9a7ecc
*color6: #4abaaf
*color14: #4abaaf
*color7: #acb0d0
*color15: #acb0d0

URxvt*.transparent: false
URxvt*.scrollBar: false
URxvt*.perl-ext-common:  default,matcher,vtwheel,clipboard,selection-to-clipboard,fullscreen,font-size
URxvt.clipboard.autocopy: true
URxvt.matcher.button: 1
URxvt*.keysym.F11: perl:fullscreen:switch
URxvt*.url-launcher:      /usr/bin/google-chrome-stable
URxvt*.matcher.button:   1
URxvt*.colorUL: #4682B4

! ! Icon
URxvt*.iconFile: /usr/share/icons/gnome/scalable/apps/utilities-terminal-symbolic.svg

! ! Ctrl-Arrow nav
URxvt*.keysym.Control-Up:   \033[1;5A
URxvt*.keysym.Control-Down:    \033[1;5B
URxvt*.keysym.Control-Left:    \033[1;5D
URxvt*.keysym.Control-Right:    \033[1;5C

URxvt*font: xft:FiraCode\ Nerd\ Font\ Mono:style=Regular:pixelsize=15:antialias=true:hinting=true
URxvt.keysym.C-Plus:     font-size:increase
URxvt.keysym.C-Minus:   font-size:decrease

URxvt.geometry:60x35
URxvt.depth:32
urxvt*background: rgba:0000/0000/0200/c800

URxvt.inheritPixmap:false
URxvt.xftAntialias:true
! ! URxvt.termName:rxvt-256color

rofi.color-enabled: true
rofi.color-window: #393939, #393939, #268bd2
rofi.color-normal: #393939, #ffffff, #393939, #268bd2, #ffffff
rofi.color-active: #393939, #268bd2, #393939, #268bd2, #205171
rofi.color-urgent: #393939, #f3843d, #393939, #268bd2, #ffc39c
