#!/usr/bin/env bash

set -euo pipefail

if [[ $# -ne 1 ]]; then
  echo "Usage: $0 <folder_path>" >&2
  exit 1
fi

target_dir="$1"

if [[ ! -d "$target_dir" ]]; then
  echo "Error: '$target_dir' is not a valid directory." >&2
  exit 1
fi

# Find all files with their size in bytes, sort ascending, format output
find "$target_dir" -type f -exec stat -f '%z' {} \; -print | \
  paste - - | \
  sort -n -k1,1 | \
  while IFS=$'\t' read -r size filepath; do
    if (( size >= 1099511627776 )); then
      formatted=$(printf '%.2fTB' "$(echo "scale=2; $size / 1099511627776" | bc)")
    elif (( size >= 1073741824 )); then
      formatted=$(printf '%.2fGB' "$(echo "scale=2; $size / 1073741824" | bc)")
    elif (( size >= 1048576 )); then
      formatted=$(printf '%.2fMB' "$(echo "scale=2; $size / 1048576" | bc)")
    else
      formatted=$(printf '%dB' "$size")
    fi
    printf '%12s    -    %s\n' "$formatted" "$filepath"
  done
