#!/usr/bin/env bash

set -eo pipefail

CUR_DIR=$(pwd)
BASE_NAME=$(basename "${CUR_DIR}")

dotfilesAttach() {
  if ! tmux list-sessions | grep -q dotfiles; then
    tmux new-session -d -s dotfiles
    tmux send-keys -t dotfiles 'dots_setup && exit' Enter
    tmux split-pane -t dotfiles
  fi

  tmux attach -t dotfiles
}

if [[ $BASE_NAME = 'ole' ]]; then
    if pgrep tmux; then
        dotfilesAttach
    else
        if ! package_check; then
            sleep 5 && bash && exit 0
        fi

        w_ssh echo "Unlocked git key"
        pass -c stardom-world.com
        if [[ -f ~/.block_pass ]]; then
            rm ~/.block_pass
        fi

        tmux new-session -d -s background
        tmux send-keys -t background 'ghsync_d' Enter

        if package_check tmux_launch_extra; then
          tmux_launch_extra
        fi

        dotfilesAttach
    fi
else
    tmux new-session -A -s "${BASE_NAME}" -c "$(pwd)"
fi
