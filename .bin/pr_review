#!/usr/bin/env bash
reponame="$(basename $1)"
prnum="$2"
branch="$3"

if [[ "$reponame" = "vcoversheet" ]]; then
  reponame="coversheet"
elif [[ "$reponame" = "tshiftbook" ]]; then
  reponame="shiftbook"
fi

if tmux list-sessions | grep -q "$reponame"; then
  if tmux list-windows -t "$reponame" | grep -v ranger | grep -qv vim; then
    sleep 0.1 && tmux send-keys -t "$reponame" "git status --porcelain && gitup -p . && pr_checkout $branch && nvim -c \"Octo pr edit $prnum\"" Enter
  fi
fi

sesh connect "code/$reponame"
