#!/usr/bin/env bash
reponame="$(basename $1)"
prnum="$2"
branch="$3"

if [[ -z $4 ]]; then
  checkout_tar="$branch"
else
  checkout_tar="$4/$branch"
fi

if [[ "$reponame" = "vcoversheet" ]]; then
  reponame="coversheet"
elif [[ "$reponame" = "tshiftbook" ]]; then
  reponame="shiftbook"
fi

sleep 0.1 && tmux send-keys -t "$reponame" "git status --porcelain && git fetch --prune && git checkout $checkout_tar && nvim -c \"Octo pr edit $prnum\"" Enter
sesh connect "code/$reponame"
